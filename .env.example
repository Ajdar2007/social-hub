# Server Configuration
PORT=5000
NODE_ENV=development

# MongoDB Connection
MONGODB_URI=mongodb://localhost:27017/social-hub
# Yaxud MongoDB Atlas üçün:
# MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/social-hub

# JWT Secret
JWT_SECRET=your_super_secret_jwt_key_here_change_this_in_production

# OpenAI API (AI Chatbot üçün)
OPENAI_API_KEY=your_openai_api_key_here

# File Upload
MAX_FILE_SIZE=52428800
UPLOAD_DIR=./uploads

# CORS
CORS_ORIGIN=http://localhost:3000,http://localhost:5000

# Email Configuration (Gələcək üçün)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password

# AI Recommendations Engine
RECOMMENDATION_ALGORITHM=collaborative
RECOMMENDATION_LIMIT=10

# 🎵 Mahnı Streaming Konfigurasyonu
MUSIC_UPLOAD_DIR=./uploads/music
MAX_MUSIC_FILE_SIZE=104857600
ALLOWED_AUDIO_FORMATS=mp3,wav,flac,m4a,ogg
MUSIC_STREAMING_QUALITY=320
MUSIC_CACHE_DIR=./cache/music

# Spotify API (Opsional - Playlist inteqrasiyası üçün)
SPOTIFY_CLIENT_ID=your_spotify_client_id
SPOTIFY_CLIENT_SECRET=your_spotify_client_secret

# AWS S3 (Mahnıları cloud-da saxlamaq üçün)
AWS_ACCESS_KEY_ID=your_aws_access_key
AWS_SECRET_ACCESS_KEY=your_aws_secret_key
AWS_S3_BUCKET=social-hub-music
AWS_REGION=us-east-1

# FFmpeg Path (Audio conversion üçün)
FFMPEG_PATH=/usr/bin/ffmpeg

# Last.fm API (Mahnı statistikası üçün)
LASTFM_API_KEY=your_lastfm_api_key